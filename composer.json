{
    "name": "devcortes/laravel-clean-architecture",
    "description": "A Laravel package to scaffold hexagonal architecture modules",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dante E. Cortés",
            "email": "dante.e.cortes@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "DevCortes\\LaravelCleanArchitecture\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevCortes\\LaravelCleanArchitecture\\DevCortesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
